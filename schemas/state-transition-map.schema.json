{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/state-transition-map.schema.json",
  "title": "State Transition Map",
  "description": "A model-independent map describing observable or declared structural changes between two temporal state records.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "transition_map_id",
    "workspace_id",
    "subject",
    "source_state",
    "target_state",
    "transition_window",
    "trigger_context",
    "change_set",
    "continuity_resolution",
    "observation",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2.0"
    },
    "record_type": {
      "type": "string",
      "const": "state_transition_map"
    },
    "transition_map_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this transition map."
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier of the temporal workspace or lifecycle."
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "source_state": {
      "$ref": "#/$defs/stateReference"
    },
    "target_state": {
      "$ref": "#/$defs/stateReference"
    },
    "transition_window": {
      "$ref": "#/$defs/transitionWindow"
    },
    "trigger_context": {
      "$ref": "#/$defs/triggerContext"
    },
    "change_set": {
      "$ref": "#/$defs/changeSet"
    },
    "continuity_resolution": {
      "$ref": "#/$defs/continuityResolution"
    },
    "observation": {
      "$ref": "#/$defs/observation"
    },
    "audit": {
      "$ref": "#/$defs/audit"
    },
    "extensions": {
      "type": "object",
      "description": "Optional implementation-specific extensions.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "subject_type"
      ],
      "properties": {
        "subject_id": {
          "type": "string",
          "minLength": 1
        },
        "subject_type": {
          "type": "string",
          "enum": [
            "model",
            "agent",
            "wing",
            "system",
            "human_ai_loop",
            "multi_agent_group",
            "other"
          ]
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "implementation": {
          "type": "string"
        }
      }
    },
    "stateReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_record_id",
        "sequence_index"
      ],
      "properties": {
        "state_record_id": {
          "type": "string",
          "minLength": 1
        },
        "sequence_index": {
          "type": "integer",
          "minimum": 0
        },
        "logical_time": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "transitionWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opened_at",
        "closed_at"
      ],
      "properties": {
        "opened_at": {
          "type": "string",
          "format": "date-time"
        },
        "closed_at": {
          "type": "string",
          "format": "date-time"
        },
        "logical_interval": {
          "type": "string",
          "minLength": 1
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "triggerContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_type"
      ],
      "properties": {
        "trigger_type": {
          "type": "string",
          "enum": [
            "external_input",
            "internal_update",
            "tool_result",
            "agent_handoff",
            "human_feedback",
            "scheduled_pulse",
            "verification_result",
            "environment_change",
            "compound",
            "unknown",
            "other"
          ]
        },
        "trigger_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "description": {
          "type": "string"
        },
        "trigger_claim_scope": {
          "type": "string",
          "enum": [
            "context_only",
            "correlated",
            "declared_driver",
            "unknown"
          ],
          "default": "context_only",
          "description": "Indicates how strongly the trigger is claimed to relate to the transition. This field does not establish causality."
        }
      }
    },
    "changeSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "introduced",
        "preserved",
        "transformed",
        "retired",
        "split",
        "merged"
      ],
      "properties": {
        "introduced": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/introducedChange"
          }
        },
        "preserved": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/preservedChange"
          }
        },
        "transformed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transformedChange"
          }
        },
        "retired": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/retiredChange"
          }
        },
        "split": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/splitChange"
          }
        },
        "merged": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mergedChange"
          }
        }
      }
    },
    "introducedChange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_id",
        "target_structure_id",
        "description"
      ],
      "properties": {
        "change_id": {
          "type": "string",
          "minLength": 1
        },
        "target_structure_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "origin_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "preservedChange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_id",
        "source_structure_id",
        "target_structure_id",
        "preservation_level"
      ],
      "properties": {
        "change_id": {
          "type": "string",
          "minLength": 1
        },
        "source_structure_id": {
          "type": "string",
          "minLength": 1
        },
        "target_structure_id": {
          "type": "string",
          "minLength": 1
        },
        "preservation_level": {
          "type": "string",
          "enum": [
            "identity_preserved",
            "meaning_preserved",
            "function_preserved",
            "partially_preserved",
            "uncertain"
          ]
        },
        "description": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "transformedChange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_id",
        "source_structure_ids",
        "target_structure_ids",
        "operation",
        "description"
      ],
      "properties": {
        "change_id": {
          "type": "string",
          "minLength": 1
        },
        "source_structure_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "target_structure_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "operation": {
          "type": "string",
          "enum": [
            "refinement",
            "generalization",
            "specialization",
            "reinterpretation",
            "translation",
            "compression",
            "expansion",
            "reordering",
            "constraint_update",
            "confidence_update",
            "other"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "meaning_retention": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "retiredChange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_id",
        "source_structure_id",
        "retirement_type"
      ],
      "properties": {
        "change_id": {
          "type": "string",
          "minLength": 1
        },
        "source_structure_id": {
          "type": "string",
          "minLength": 1
        },
        "retirement_type": {
          "type": "string",
          "enum": [
            "resolved",
            "superseded",
            "rejected",
            "expired",
            "deprioritized",
            "lost",
            "unknown"
          ]
        },
        "description": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "splitChange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_id",
        "source_structure_id",
        "target_structure_ids",
        "description"
      ],
      "properties": {
        "change_id": {
          "type": "string",
          "minLength": 1
        },
        "source_structure_id": {
          "type": "string",
          "minLength": 1
        },
        "target_structure_ids": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "mergedChange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_id",
        "source_structure_ids",
        "target_structure_id",
        "description"
      ],
      "properties": {
        "change_id": {
          "type": "string",
          "minLength": 1
        },
        "source_structure_ids": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "target_structure_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "continuityResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolved_candidates",
        "still_open_candidates"
      ],
      "properties": {
        "resolved_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resolvedContinuityCandidate"
          }
        },
        "still_open_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/openContinuityCandidate"
          }
        }
      }
    },
    "resolvedContinuityCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "resolution"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "resolution": {
          "type": "string",
          "enum": [
            "preserved",
            "revisited",
            "transformed",
            "verified",
            "handed_off",
            "retired"
          ]
        },
        "resulting_structure_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "description": {
          "type": "string"
        }
      }
    },
    "openContinuityCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "status"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "deferred",
            "blocked",
            "unknown"
          ]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basis",
        "confidence"
      ],
      "properties": {
        "basis": {
          "type": "string",
          "enum": [
            "state_comparison",
            "trace_inference",
            "telemetry",
            "self_report",
            "external_observation",
            "hybrid"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "comparison_method": {
          "type": "string",
          "enum": [
            "manual",
            "rule_based",
            "model_assisted",
            "automated",
            "hybrid"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_by",
        "human_review_required"
      ],
      "properties": {
        "created_by": {
          "type": "string",
          "minLength": 1
        },
        "human_review_required": {
          "type": "boolean"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "not_requested",
            "pending",
            "reviewed",
            "rejected"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
